# Otherland — environment variables template
# Copy to .env.local and fill in. NEVER commit real values.

# ─────────────────────────────────────────────────────────────
# Payload CMS  (адмінка /admin + джерело даних сайту)
# ─────────────────────────────────────────────────────────────
# Supabase Postgres — Session pooler (порт 5432!), Connect → Session pooler → URI
DATABASE_URL=postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres
PAYLOAD_SECRET=                      # openssl rand -base64 32
NEXT_PUBLIC_SERVER_URL=http://localhost:3000
# Кількість конектів пулу Payload (Supabase session pooler ліміт = 15). Білд не пре-рендерить тули.
PG_POOL_MAX=3

# Supabase Storage (S3) для медіа в адмінці — Dashboard → Storage → S3 Access Keys
S3_BUCKET=tool-screenshots
S3_ENDPOINT=https://<ref>.storage.supabase.co/storage/v1/s3
S3_REGION=                           # регіон проєкту (напр. eu-west-1)
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
SUPABASE_URL=https://<ref>.supabase.co   # для generateFileURL медіа

# ─────────────────────────────────────────────────────────────
# Supabase
# Dashboard: https://supabase.com/dashboard/project/<your-ref>/settings/api
# ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only — used by n8n, screenshot service, and admin scripts.
# Bypasses Row Level Security. Treat as a master password.
SUPABASE_SERVICE_ROLE_KEY=

# ─────────────────────────────────────────────────────────────
# OpenRouter (research + enrichment via Perplexity Sonar / GPT-4o)
# Get key: https://openrouter.ai/keys  · Fund: $20+ recommended
# ─────────────────────────────────────────────────────────────
OPENROUTER_API_KEY=

# ─────────────────────────────────────────────────────────────
# Telegram (approval channel for new tools)
# Bot:     create via @BotFather → /newbot → copy token below
# Channel: create channel, add bot as admin, then get chat_id
#          (e.g. forward a message to @userinfobot, take the channel id)
# ─────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHANNEL_ID=

# ─────────────────────────────────────────────────────────────
# Optional — screenshot microservice (only if running automation/screenshot-service.js)
# Default: http://localhost:3001
# Production: set to your hosted Playwright service URL
# ─────────────────────────────────────────────────────────────
SCREENSHOT_SERVICE_URL=

# ─────────────────────────────────────────────────────────────
# Автоматизація (automation/.env) — bot.js / research.js пишуть у Payload через REST
# ─────────────────────────────────────────────────────────────
# URL запущеного Next+Payload (локально http://localhost:3000, прод — твій домен)
PAYLOAD_API_URL=http://localhost:3000
# API-key сервісного користувача: npx tsx scripts/create-service-user.ts
PAYLOAD_API_KEY=

# ─────────────────────────────────────────────────────────────
# Optional — n8n webhook URL for user submission form on the site
# ─────────────────────────────────────────────────────────────
N8N_WEBHOOK_URL=
