{
  "name": "ai-land-automation",
  "version": "1.0.0",
  "description": "Screenshot microservice for AI Land — Playwright + Supabase Storage",
  "type": "module",
  "main": "screenshot-service.js",
  "scripts": {
    "screenshot": "node screenshot-service.js",
    "screenshot:dev": "node --watch screenshot-service.js",
    "install:browsers": "npx playwright install chromium",
    "research": "node research.js",
    "bot": "node bot.js",
    "bot:dev": "node --watch bot.js"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.43.0",
    "dotenv": "^16.4.5",
    "express": "^4.19.0",
    "playwright": "^1.44.0",
    "telegraf": "^4.16.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
